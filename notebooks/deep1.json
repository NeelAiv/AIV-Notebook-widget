[{"cell_type": "code", "source": "import matplotlib.pyplot as plt\n\n# Data\ncategories = ['A', 'B', 'C', 'D']\nvalues = [10, 24, 36, 18]\n\n# Create bar chart\nplt.bar(categories, values)\n\n# Labels and title\nplt.xlabel('Categories')\nplt.ylabel('Values')\nplt.title('Simple Bar Chart')\n\n# Show chart\nplt.show()\n", "output": "<img src=\"data:image/png;base64,\" style=\"max-width: 100%;\">"}, {"cell_type": "markdown", "source": "asdfg"}]